# ArcadeX .gitignore

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Node.js (if added later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Build artifacts
dist/
build/

# Temporary files
*.tmp
*.temp
.cache/

# Logs
*.log
logs/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Browser cache and local storage
.cache/
.localstorage/

# Screenshots and exports
screenshots/
exports/

# Backup files
*.bak
*.backup
*.old

# Windows executables
*.exe
*.dll
*.lib

# Game saves and user data
saves/
user-data/

# Performance logs
performance.json
fps-log.txt